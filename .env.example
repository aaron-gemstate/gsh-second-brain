# Slack Bot credentials
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
# Optional: only needed for Socket Mode (dev/no-public-URL)
SLACK_APP_TOKEN=xapp-...

# The channel ID for #second-brain (not the name)
SLACK_SECOND_BRAIN_CHANNEL_ID=C0XXXXXXXXX

# #ask-helgi direct channel — Helgi responds to @-mentions here
# Channel ID for #ask-helgi (private channel, bot must be a member)
SLACK_ASK_HELGI_CHANNEL_ID=C0B278NRU9H
# Helgi's Slack user ID (the @helgi account people @-mention)
SLACK_HELGI_USER_ID=U0B2B7ZKXQD
# Helgi's Paperclip agent ID — issues are assigned directly (bypassing triage)
PAPERCLIP_HELGI_AGENT_ID=f38f1ce4-da95-4584-84b6-81b7f592b070

# Paperclip
PAPERCLIP_API_URL=http://100.91.194.101:3100
PAPERCLIP_API_KEY=...
PAPERCLIP_COMPANY_ID=fb4f5ce8-d2ce-4609-b6b7-87fea8b7ab14
PAPERCLIP_PROJECT_ID=47b6b026-f323-47d7-8c0a-b7a5fc49ef43
PAPERCLIP_COMPANY_PREFIX=GEM
APP_BASE_URL=https://paperclip.ing
# Set after hiring the Triage Agent — issues will be auto-assigned to it
PAPERCLIP_TRIAGE_AGENT_ID=

# GitHub — second-brain database
# Fine-grained PAT with Issues: read/write on the target repo
GITHUB_TOKEN=ghp_...
# Owner (org or user) that owns the repo
GITHUB_REPO_OWNER=gemstateholdings
# Repo name (defaults to gsh-second-brain if omitted)
GITHUB_REPO_NAME=gsh-second-brain
# Comma-separated labels to apply on every issue (must already exist in the repo)
GITHUB_DEFAULT_LABELS=second-brain,idea
# Optional: comma-separated GitHub usernames to auto-assign all ideas
GITHUB_DEFAULT_ASSIGNEES=

# HTTP server port (ignored in Socket Mode)
PORT=3000

# QuickBooks Online Payroll Integration (GEM-129)
# OAuth2 app credentials from Intuit Developer portal
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
# Long-lived refresh token (obtained via OAuth2 authorization flow)
QBO_REFRESH_TOKEN=
# QBO Company (Realm) ID — found in QBO URL after /app/homepage
QBO_REALM_ID=
# "production" or "sandbox" (use sandbox for testing)
QBO_ENVIRONMENT=production
# Set to "true" once Intuit confirms Payroll API tier access
# Required for: pay rate, W-4 filing status, direct deposit
QBO_PAYROLL_TIER_ENABLED=false
